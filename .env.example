# PostgreSQL Connection String (e.g. from Neon.tech, Supabase, or local PG)
DATABASE_URL=postgresql://neondb_owner:password@ep-example.eastus2.azure.neon.tech/neondb?sslmode=require

# Port for the API server (defaults to 8080)
PORT=8080

# Live market data API key (Optional. If not set, the app will run in simulated demo mode)
# UPSTOX_API_KEY=your_upstox_api_key_here
